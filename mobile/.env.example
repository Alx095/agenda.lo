EXPO_PUBLIC_API_URL=http://localhost:3000

# Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Physical device on same Wi-Fi (replace with your PC IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Railway production:
# EXPO_PUBLIC_API_URL=https://agendalo-production-b282.up.railway.app

# Expo push notifications (EAS project ID from expo.dev)
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
