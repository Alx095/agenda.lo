# Local development only — never commit .env to GitHub.
# On Render, set these variables in the Web Service dashboard.

NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://user:password@localhost:5432/appointments_db"

JWT_SECRET="change-me-to-a-long-random-secret-min-16-chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Development: leave empty to allow all origins (Expo / localhost).
# Render production: use * or comma-separated origins, e.g.:
# CORS_ORIGIN=http://localhost:8081,http://localhost:19006,https://tu-app.onrender.com
CORS_ORIGIN=

# Render notes:
# - Do NOT set PORT manually — Render injects it automatically.
# - DATABASE_URL: link PostgreSQL database in Render dashboard.
# - Use Internal Database URL for the web service in the same region.
# - NODE_ENV=production
