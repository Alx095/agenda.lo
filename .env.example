# Local development only — never commit .env to GitHub.
# On Railway, set these variables in the service dashboard.

NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://user:password@localhost:5432/appointments_db"

JWT_SECRET="change-me-to-a-long-random-secret-min-16-chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Development: leave empty to allow all origins (Expo / localhost).
# Production (Railway): required. Comma-separated, e.g. https://app.example.com
# Or use * for Expo web development
CORS_ORIGIN=

# Resend email (optional in development)
# Sandbox: onboarding@resend.dev only delivers to your Resend account email.
# For other recipients, verify a domain at resend.com/domains.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Public API URL for email verification links (required in production)
APP_URL=http://localhost:3000

# Railway notes:
# - Do NOT set PORT manually on Railway — it is injected automatically.
# - DATABASE_URL: reference from PostgreSQL service → ${{Postgres.DATABASE_URL}}
# - NODE_ENV=production
